# Szablon zmiennych środowiskowych — commitowany do repo.
# Skopiuj jako .env.local (dev lokalny), .env.dev (dev server) lub .env.prod (prod).
#
# Zmienne:
#   VITE_API_BASE  — bazowy URL backendu widoczny z przeglądarki.
#                    W deployach Docker nginx w kontenerze proxy-uje /api → profiler-backend:8100,
#                    więc wartość /api działa we wszystkich środowiskach.
#                    Zmień tylko jeśli backend wystawiony jest pod innym URL (np. direct bez nginx).

VITE_API_BASE=/api
